// firestore.rules
// ─────────────────────────────────────────────────────────
// Deploy via: firebase deploy --only firestore:rules
// Or paste directly in Firebase Console →
//   Firestore → Rules tab
// ─────────────────────────────────────────────────────────

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Posts ─────────────────────────────────────────
    match /posts/{postId} {
      // Anyone logged in can read posts
      allow read: if request.auth != null;

      // Only authenticated users can create posts
      // and the userId must match their real UID
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      // Only the post author can update/delete
      allow update: if request.auth != null
        && (
          // Author can edit their own post
          resource.data.userId == request.auth.uid
          ||
          // Any logged-in user can like/unlike
          // (only likes and likedBy fields change)
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likes', 'likedBy'])
        );

      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // ── Users (for future profile phase) ──────────────
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId;
    }
  }
}
